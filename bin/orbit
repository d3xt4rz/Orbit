#!/bin/bash
# orbit - Ferramenta de gerenciamento remoto

# === Detecção robusta do diretório raiz ===
ORBIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export ORBIT_HOME
ORBIT_USER="${ORBIT_USER:-$(whoami)}"

# === Função segura para carregar bibliotecas ===
_load_lib() {
    local lib_file="$ORBIT_HOME/lib/$1"
    if [[ -f "$lib_file" ]]; then
        source "$lib_file"
    else
        echo -e "\033[1;31mERRO:\033[0m Biblioteca '$1' não encontrada em $lib_file" >&2
        exit 1
    fi
}

_load_lib "core.sh"
_load_lib "mount.sh"
_load_lib "ssh.sh"

# === Carregar configurações ===
if [[ -f "$ORBIT_HOME/conf/orbit.conf" ]]; then
    source "$ORBIT_HOME/conf/orbit.conf"
else
    _orbit_log WARN "Arquivo de configuração não encontrado em $ORBIT_HOME/conf/orbit.conf"
    _orbit_log INFO "Usando valores padrão internos..."
fi

# Sobrescrita por configuração pessoal (opcional)
if [[ -f "$HOME/.orbit.conf" ]]; then
    source "$HOME/.orbit.conf"
fi

# === Verificar dependências ===
if ! command -v sshfs &>/dev/null; then
    _orbit_log ERROR "sshfs não está instalado. Instale com: sudo apt install sshfs"
    exit 1
fi

# === Banner ===
ORBIT_BANNER="
${ORBIT_COLOR_CYAN}
 ██████╗ ██████╗ ██████╗ ██╗████████╗
██╔═══██╗██╔══██╗██╔══██╗██║╚══██╔══╝
██║   ██║██████╔╝██████╔╝██║   ██║   
██║   ██║██╔══██╗██╔══██╗██║   ██║   
╚██████╔╝██║  ██║██████╔╝██║   ██║   
 ╚═════╝ ╚═╝  ╚═╝╚═════╝ ╚═╝   ╚═╝   ${ORBIT_COLOR_RESET}"

show_banner() {
    echo -e "$ORBIT_BANNER"
}

_orbit_hline() {
    echo -e "${ORBIT_COLOR_GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${ORBIT_COLOR_RESET}"
}

# === Ajuda ===
orbit_help() {
    echo -e "${ORBIT_COLOR_CYAN}Orbit - Ferramenta de gerenciamento remoto${ORBIT_COLOR_RESET}"
    _orbit_hline
    echo ""
    echo -e "${ORBIT_COLOR_YELLOW}Subcomandos:${ORBIT_COLOR_RESET}"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir start${ORBIT_COLOR_RESET}    - Monta a pasta remota"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir kill${ORBIT_COLOR_RESET}     - Desmonta a pasta remota"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir status${ORBIT_COLOR_RESET}   - Verifica status da montagem"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit ssh${ORBIT_COLOR_RESET}          - Conecta via SSH"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit help${ORBIT_COLOR_RESET}         - Exibe esta ajuda"
    echo ""
    echo -e "${ORBIT_COLOR_YELLOW}Configuração:${ORBIT_COLOR_RESET}"
    echo -e "  Edite o arquivo: ${ORBIT_COLOR_GREEN}$ORBIT_HOME/conf/orbit.conf${ORBIT_COLOR_RESET}"
    echo ""
}

# === Menu interativo ===
orbit_menu() {
    local menu_lines=(
        "  ${ORBIT_COLOR_GREEN}ssh${ORBIT_COLOR_RESET}          - Conecta via SSH"
        "  ${ORBIT_COLOR_GREEN}dir start${ORBIT_COLOR_RESET}    - Monta a pasta remota"
        "  ${ORBIT_COLOR_GREEN}dir kill${ORBIT_COLOR_RESET}     - Desmonta a pasta remota"
        "  ${ORBIT_COLOR_GREEN}dir status${ORBIT_COLOR_RESET}   - Verifica status da montagem"
        "  ${ORBIT_COLOR_GREEN}help${ORBIT_COLOR_RESET}         - Exibe esta ajuda"
        "  Sair"
    )

    local -a menu_commands=(
        "orbit_ssh"
        "orbit_dir start"
        "orbit_dir kill"
        "orbit_dir status"
        "orbit_help"
        "sair"
    )

    local selected=0
    local total=${#menu_lines[@]}
    local key

    tput civis   # esconde cursor

    while true; do
        clear
        show_banner
        echo -e "${ORBIT_COLOR_CYAN}Orbit - Ferramenta de gerenciamento remoto${ORBIT_COLOR_RESET}"
        _orbit_hline
        echo ""
        echo -e "${ORBIT_COLOR_YELLOW}Subcomandos:${ORBIT_COLOR_RESET}"

        for i in "${!menu_lines[@]}"; do
            if [[ $i -eq $selected ]]; then
                echo -e " ${ORBIT_COLOR_GREEN}▶${ORBIT_COLOR_RESET}${menu_lines[$i]:1}"
            else
                echo -e "${menu_lines[$i]}"
            fi
        done

        echo ""
        echo -e "${ORBIT_COLOR_YELLOW}Configuração:${ORBIT_COLOR_RESET}"
        echo -e "  Edite o arquivo: ${ORBIT_COLOR_GREEN}$ORBIT_HOME/conf/orbit.conf${ORBIT_COLOR_RESET}"

        read -s -n 1 key
        if [[ $key == $'\e' ]]; then
            read -s -n 1 key2
            if [[ $key2 == '[' ]]; then
                read -s -n 1 key3
                case $key3 in
                    A) ((selected > 0)) && ((selected--)) ;;
                    B) ((selected < total - 1)) && ((selected++)) ;;
                esac
            fi
        elif [[ $key == '' ]]; then
            local cmd="${menu_commands[$selected]}"

            # === SAIR COM ESTILO ===
            if [[ "$cmd" == "sair" ]]; then
                tput cnorm
                clear
                show_banner
                _orbit_hline
                echo -e "  ${ORBIT_COLOR_GREEN}✨ Orbit encerrado com sucesso! ✨${ORBIT_COLOR_RESET}"
                echo -e "  ${ORBIT_COLOR_GRAY}Até logo, ${ORBIT_USER:-usuário}! 🚀${ORBIT_COLOR_RESET}"
                _orbit_hline
                sleep 1.5
                exit 0
            fi

            clear
            show_banner
            _orbit_hline

            case "$cmd" in
                "orbit_ssh")
                    _orbit_log INFO "Iniciando conexão SSH..."
                    _orbit_log INFO "Host: ${ORBIT_SSH_HOST:-209.50.241.196}:${ORBIT_SSH_PORT:-22}"
                    _orbit_log INFO "Usuário: ${ORBIT_SSH_USER:-root}"
                    echo ""
                    orbit_ssh
                    local exit_code=$?
                    echo ""
                    if [[ $exit_code -eq 0 ]]; then
                        _orbit_log SUCCESS "Sessão SSH encerrada"
                    else
                        _orbit_log ERROR "Falha na conexão SSH (código: $exit_code)"
                    fi
                    ;;

                "orbit_dir start"|"orbit_dir kill"|"orbit_dir status")
                    local action="${cmd#orbit_dir }"
                    orbit_dir "$action"
                    ;;

                "orbit_help")
                    orbit_help
                    ;;

                *)
                    _orbit_log ERROR "Comando inválido: $cmd"
                    ;;
            esac

            _orbit_hline
            echo ""
            echo -e "  ${ORBIT_COLOR_GRAY}Pressione qualquer tecla para voltar ao menu...${ORBIT_COLOR_RESET}"
            read -s -n 1
        fi
    done
}

# === Modo direto (com argumentos) ===
main() {
    if [[ $# -eq 0 ]]; then
        orbit_menu
        exit 0
    fi

    clear
    show_banner
    local cmd="$1"; shift 2>/dev/null || true

    case "$cmd" in
        dir|mount)
            orbit_dir "$@"
            ;;
        ssh|connect)
            orbit_ssh "$@"
            ;;
        help|--help|-h)
            orbit_help
            ;;
        *)
            _orbit_log ERROR "Comando desconhecido: $cmd"
            _orbit_log INFO "Use 'orbit help' para ver os comandos disponíveis"
            exit 1
            ;;
    esac
}

main "$@"