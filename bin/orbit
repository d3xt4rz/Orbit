#!/bin/bash
# orbit - Ferramenta de gerenciamento remoto

# Detecta o diret├│rio raiz do projeto
ORBIT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export ORBIT_HOME

# Carrega bibliotecas
_load_lib() {
    local lib_file="$ORBIT_HOME/lib/$1"
    if [[ -f "$lib_file" ]]; then
        source "$lib_file"
    else
        echo -e "\033[1;31mERRO:\033[0m Biblioteca '$1' n├гo encontrada em $lib_file" >&2
        exit 1
    fi
}

_load_lib "core.sh"
_load_lib "mount.sh"
_load_lib "ssh.sh"

# Carrega configura├з├гo do projeto
if [[ -f "$ORBIT_HOME/conf/orbit.conf" ]]; then
    source "$ORBIT_HOME/conf/orbit.conf"
else
    _orbit_log WARN "Arquivo de configura├з├гo n├гo encontrado em $ORBIT_HOME/conf/orbit.conf"
    _orbit_log INFO "Usando valores padr├гo internos..."
fi

if [[ -f "$HOME/.orbit.conf" ]]; then
    source "$HOME/.orbit.conf"
fi

# Verifica depend├кncias
if ! command -v sshfs &>/dev/null; then
    _orbit_log ERROR "sshfs n├гo est├б instalado. Instale com: sudo apt install sshfs"
    exit 1
fi

# Banner
ORBIT_BANNER="
${ORBIT_COLOR_CYAN} тЦИтЦИтЦИтЦИтЦИтЦИтХЧ тЦИтЦИтЦИтЦИтЦИтЦИтХЧ тЦИтЦИтЦИтЦИтЦИтЦИтХЧ тЦИтЦИтХЧтЦИтЦИтЦИтЦИтЦИтЦИтЦИтЦИтХЧ
тЦИтЦИтХФтХРтХРтХРтЦИтЦИтХЧтЦИтЦИтХФтХРтХРтЦИтЦИтХЧтЦИтЦИтХФтХРтХРтЦИтЦИтХЧтЦИтЦИтХСтХЪтХРтХРтЦИтЦИтХФтХРтХРтХЭ
тЦИтЦИтХС   тЦИтЦИтХСтЦИтЦИтЦИтЦИтЦИтЦИтХФтХЭтЦИтЦИтЦИтЦИтЦИтЦИтХФтХЭтЦИтЦИтХС   тЦИтЦИтХС   
тЦИтЦИтХС   тЦИтЦИтХСтЦИтЦИтХФтХРтХРтЦИтЦИтХЧтЦИтЦИтХФтХРтХРтЦИтЦИтХЧтЦИтЦИтХС   тЦИтЦИтХС   
тХЪтЦИтЦИтЦИтЦИтЦИтЦИтХФтХЭтЦИтЦИтХС  тЦИтЦИтХСтЦИтЦИтЦИтЦИтЦИтЦИтХФтХЭтЦИтЦИтХС   тЦИтЦИтХС   
 тХЪтХРтХРтХРтХРтХРтХЭ тХЪтХРтХЭ  тХЪтХРтХЭтХЪтХРтХРтХРтХРтХРтХЭ тХЪтХРтХЭ   тХЪтХРтХЭ   ${ORBIT_COLOR_RESET}"

show_banner() {
    echo -e "$ORBIT_BANNER"
}

_orbit_hline() {
    echo -e "${ORBIT_COLOR_GRAY}тФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБ${ORBIT_COLOR_RESET}"
}

orbit_help() {
    echo -e "${ORBIT_COLOR_CYAN}Orbit - Ferramenta de gerenciamento remoto${ORBIT_COLOR_RESET}"
    _orbit_hline
    echo ""
    echo -e "${ORBIT_COLOR_YELLOW}Subcomandos:${ORBIT_COLOR_RESET}"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir start${ORBIT_COLOR_RESET}    - Monta a pasta remota"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir kill${ORBIT_COLOR_RESET}     - Desmonta a pasta remota"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit dir status${ORBIT_COLOR_RESET}   - Verifica status da montagem"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit ssh${ORBIT_COLOR_RESET}          - Conecta via SSH"
    echo -e "  ${ORBIT_COLOR_GREEN}orbit help${ORBIT_COLOR_RESET}         - Exibe esta ajuda"
    echo ""
    echo -e "${ORBIT_COLOR_YELLOW}Configura├з├гo:${ORBIT_COLOR_RESET}"
    echo -e "  Edite o arquivo: ${ORBIT_COLOR_GREEN}$ORBIT_HOME/conf/orbit.conf${ORBIT_COLOR_RESET}"
    echo ""
}

orbit_menu() {
    local menu_lines=(
        "  ${ORBIT_COLOR_GREEN}ssh${ORBIT_COLOR_RESET}          - Conecta via SSH"
        "  ${ORBIT_COLOR_GREEN}dir start${ORBIT_COLOR_RESET}    - Monta a pasta remota"
        "  ${ORBIT_COLOR_GREEN}dir kill${ORBIT_COLOR_RESET}     - Desmonta a pasta remota"
        "  ${ORBIT_COLOR_GREEN}dir status${ORBIT_COLOR_RESET}   - Verifica status da montagem"
        "  ${ORBIT_COLOR_GREEN}help${ORBIT_COLOR_RESET}         - Exibe esta ajuda"
        "  Sair"
    )

    local -a menu_commands=(
        "orbit_ssh"
        "orbit_dir start"
        "orbit_dir kill"
        "orbit_dir status"
        "orbit_help"
        "sair"
    )

    local selected=0
    local total=${#menu_lines[@]}
    local key

    tput civis

    while true; do
        clear
        show_banner
        echo -e "${ORBIT_COLOR_CYAN}Orbit - Ferramenta de gerenciamento remoto${ORBIT_COLOR_RESET}"
        _orbit_hline
        echo ""
        echo -e "${ORBIT_COLOR_YELLOW}Subcomandos:${ORBIT_COLOR_RESET}"

        for i in "${!menu_lines[@]}"; do
            if [[ $i -eq $selected ]]; then
                echo -e " ${ORBIT_COLOR_GREEN}тЦ╢${ORBIT_COLOR_RESET}${menu_lines[$i]:1}"
            else
                echo -e "${menu_lines[$i]}"
            fi
        done

        echo ""
        echo -e "${ORBIT_COLOR_YELLOW}Configura├з├гo:${ORBIT_COLOR_RESET}"
        echo -e "  Edite o arquivo: ${ORBIT_COLOR_GREEN}$ORBIT_HOME/conf/orbit.conf${ORBIT_COLOR_RESET}"

        read -s -n 1 key
        if [[ $key == $'\e' ]]; then
            read -s -n 1 key2
            if [[ $key2 == '[' ]]; then
                read -s -n 1 key3
                case $key3 in
                    A) ((selected > 0)) && ((selected--)) ;;
                    B) ((selected < total - 1)) && ((selected++)) ;;
                esac
            fi
        elif [[ $key == '' ]]; then
            local cmd="${menu_commands[$selected]}"

            if [[ "$cmd" == "sair" ]]; then
                tput cnorm
                clear
                show_banner
                _orbit_hline
                echo -e "  ${ORBIT_COLOR_GREEN}тЬи Orbit encerrado com sucesso! тЬи${ORBIT_COLOR_RESET}"
                echo -e "  ${ORBIT_COLOR_GRAY}At├й logo, e bons voos! ЁЯЪА${ORBIT_COLOR_RESET}"
                _orbit_hline
                sleep 1.5
                exit 0
            fi

            clear
            show_banner
            _orbit_hline

            case "$cmd" in
                "orbit_ssh")
                    _orbit_log INFO "Iniciando conex├гo SSH..."
                    _orbit_log INFO "Host: ${ORBIT_SSH_HOST:-209.50.241.196}:${ORBIT_SSH_PORT:-22}"
                    _orbit_log INFO "Usu├бrio: ${ORBIT_SSH_USER:-root}"
                    echo ""
                    orbit_ssh
                    local exit_code=$?
                    echo ""
                    if [[ $exit_code -eq 0 ]]; then
                        _orbit_log SUCCESS "Sess├гo SSH encerrada"
                    else
                        _orbit_log ERROR "Falha na conex├гo SSH (c├│digo: $exit_code)"
                    fi
                    ;;

                "orbit_dir start"|"orbit_dir kill"|"orbit_dir status")
                    local action="${cmd#orbit_dir }"
                    orbit_dir "$action"
                    ;;

                "orbit_help")
                    orbit_help
                    ;;

                *)
                    _orbit_log ERROR "Comando inv├бlido: $cmd"
                    ;;
            esac

            _orbit_hline
            echo ""
            echo -e "  ${ORBIT_COLOR_GRAY}Pressione qualquer tecla para voltar ao menu...${ORBIT_COLOR_RESET}"
            read -s -n 1
        fi
    done
}

main() {
    if [[ $# -eq 0 ]]; then
        orbit_menu
        exit 0
    fi

    clear
    show_banner
    _orbit_hline                         # тЖР linha antes

    local cmd="$1"; shift 2>/dev/null || true

    case "$cmd" in
        dir|mount)
            orbit_dir "$@"
            ;;
        ssh|connect)
            _orbit_log INFO "Iniciando conex├гo SSH..."
            _orbit_log INFO "Host: ${ORBIT_SSH_HOST:-209.50.241.196}:${ORBIT_SSH_PORT:-22}"
            _orbit_log INFO "Usu├бrio: ${ORBIT_SSH_USER:-root}"
            echo ""
            orbit_ssh "$@"
            local exit_code=$?
            echo ""
            if [[ $exit_code -eq 0 ]]; then
                _orbit_log SUCCESS "Sess├гo SSH encerrada"
            else
                _orbit_log ERROR "Falha na conex├гo SSH (c├│digo: $exit_code)"
            fi
            ;;
        help|--help|-h)
            orbit_help
            ;;
        *)
            _orbit_log ERROR "Comando desconhecido: $cmd"
            _orbit_log INFO "Use 'orbit help' para ver os comandos dispon├нveis"
            exit 1
            ;;
    esac

    _orbit_hline                         # тЖР linha depois
}

main "$@"
